---
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section id="varolista" class="waitlist-section animate-on-scroll py-24">
  <div class="max-w-7xl mx-auto px-6">

    <div class="waitlist-inner rounded-3xl px-8 py-16 sm:px-16 text-center relative overflow-hidden">

      <!-- Background decoration -->
      <div class="pointer-events-none absolute -top-24 -right-24 w-72 h-72 rounded-full"
        style="background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%); opacity: 0.15;"
        aria-hidden="true"></div>
      <div class="pointer-events-none absolute -bottom-16 -left-16 w-56 h-56 rounded-full"
        style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%); opacity: 0.12;"
        aria-hidden="true"></div>

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium mb-6"
        style="background: var(--color-primary-light); color: var(--color-primary);">
        <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
        Hamarosan nyílik a regisztráció
      </div>

      <!-- Headline -->
      <h2 class="font-heading text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-4"
        style="color: var(--color-text);">
        Légy az elsők között
      </h2>
      <p class="text-lg leading-relaxed max-w-lg mx-auto mb-10"
        style="color: var(--color-text-secondary);">
        Iratkozz fel a várólista, és értesítünk, amint megnyílik a regisztráció.
      </p>

      <!-- Form -->
      <form id="waitlist-form" data-key={web3formsKey} novalidate class="relative z-10">
        <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-3">
          <input
            id="waitlist-name"
            name="name"
            type="text"
            autocomplete="name"
            placeholder="Neved"
            class="waitlist-input flex-1 rounded-xl py-3.5 px-4 text-base border outline-none transition-shadow duration-150"
            style="border-color: var(--color-border); color: var(--color-text); background-color: var(--color-bg);"
          />
        </div>
        <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            id="waitlist-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="E-mail cím"
            class="waitlist-input flex-1 rounded-xl py-3.5 px-4 text-base border outline-none transition-shadow duration-150"
            style="border-color: var(--color-border); color: var(--color-text); background-color: var(--color-bg);"
          />
          <button
            id="waitlist-submit"
            type="submit"
            class="waitlist-btn inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl text-base font-semibold text-white transition-all duration-200 hover:brightness-110 active:scale-[0.98] shrink-0"
            style="background-color: var(--color-primary);"
          >
            <span id="waitlist-btn-label">Feliratkozom</span>
            <svg id="waitlist-btn-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg id="waitlist-spinner" class="hidden animate-spin" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="2" stroke-dasharray="32" stroke-dashoffset="12" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <!-- Inline error -->
        <p id="waitlist-error" class="hidden mt-3 text-sm font-medium" style="color: #dc2626;" role="alert" aria-live="polite"></p>
      </form>

      <!-- Success state (hidden by default) -->
      <div
        id="waitlist-success"
        class="hidden relative z-10"
        role="alert"
        aria-live="polite"
      >
        <div
          class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-5"
          style="background-color: color-mix(in srgb, var(--color-primary) 12%, transparent);"
        >
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <path d="M5.5 14 11 19.5 22.5 8" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <p class="text-xl font-bold mb-2" style="font-family: var(--font-heading); color: var(--color-text);">
          Köszönjük!
        </p>
        <p class="text-base" style="color: var(--color-text-secondary);">
          Értesítünk, amint megnyílik a regisztráció.
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  .waitlist-section {
    background-color: var(--color-bg);
  }

  .waitlist-inner {
    background: color-mix(in srgb, var(--color-primary-light) 40%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-primary) 15%, var(--color-border));
  }

  .waitlist-input:focus {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-primary);
    border-color: var(--color-primary);
  }

  .waitlist-btn:hover {
    box-shadow: 0 8px 25px color-mix(in srgb, var(--color-primary) 35%, transparent);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 0.8s linear infinite;
  }
</style>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement | null;
  const successEl = document.getElementById("waitlist-success");
  const errorEl = document.getElementById("waitlist-error");
  const submitBtn = document.getElementById("waitlist-submit") as HTMLButtonElement | null;
  const btnLabel = document.getElementById("waitlist-btn-label");
  const btnIcon = document.getElementById("waitlist-btn-icon");
  const spinner = document.getElementById("waitlist-spinner");

  const WEB3FORMS_KEY = form?.dataset.key ?? "";

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    btnLabel?.classList.toggle("opacity-0", loading);
    btnIcon?.classList.toggle("hidden", loading);
    spinner?.classList.toggle("hidden", !loading);
  }

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  function clearError() {
    if (!errorEl) return;
    errorEl.textContent = "";
    errorEl.classList.add("hidden");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearError();

    const emailInput = document.getElementById("waitlist-email") as HTMLInputElement;
    const nameInput = document.getElementById("waitlist-name") as HTMLInputElement;

    const email = emailInput?.value.trim();
    const name = nameInput?.value.trim() || "";

    if (!email) {
      showError("Kérlek, adj meg egy e-mail címet.");
      emailInput?.focus();
      return;
    }

    setLoading(true);

    try {
      const formData = new FormData();
      formData.append("access_key", WEB3FORMS_KEY);
      formData.append("subject", "📋 Kuppo — Új várólista feliratkozás");
      formData.append("from_name", "Kuppo Landing");
      formData.append("email", email);
      if (name) formData.append("name", name);
      formData.append("botcheck", "");

      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();

      if (!data.success) {
        throw new Error(data.message || "Web3Forms error");
      }

      form.classList.add("hidden");
      successEl?.classList.remove("hidden");
    } catch (err) {
      showError("Valami hiba történt. Kérlek, próbáld újra.");
      console.error("Waitlist submit error:", err);
    } finally {
      setLoading(false);
    }
  });
</script>

---
import TrendingUp from "@lucide/astro/icons/trending-up";
---

<div
  class="w-full py-8 px-6"
  style="background-color: var(--color-primary-light); border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-primary) 8%, transparent);"
>
  <div class="flex flex-col items-center gap-2 text-center">
    <div class="flex items-center gap-2">
      <TrendingUp
        size={22}
        aria-hidden="true"
        style="color: var(--color-primary); flex-shrink: 0;"
      />
      <span class="text-4xl font-bold" style="color: var(--color-primary);">67%</span>
    </div>
    <p class="text-base" style="color: var(--color-text-secondary);">A visszatérő vásárlók ennyivel többet költenek — Bain & Company</p>
  </div>
</div>

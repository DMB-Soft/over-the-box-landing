---
import Send from "@lucide/astro/icons/send";
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section id="kapcsolat" class="contact-section py-24 animate-on-scroll">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-3" style="color: var(--color-text);">
        Kapcsolat
      </h2>
      <p class="text-lg leading-relaxed max-w-xl mx-auto" style="color: var(--color-text-secondary);">
        Kérdésed van? Írj nekünk, és hamarosan válaszolunk!
      </p>
    </div>

    <div class="flex justify-center">
      <div
        class="contact-card w-full max-w-lg rounded-2xl border p-8 sm:p-10 transition-all duration-300"
        style="border-color: var(--color-border); background-color: var(--color-surface); box-shadow: 0 4px 24px rgba(0,0,0,0.06);"
      >

        <!-- Form -->
        <form id="contact-form" novalidate>
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="📬 Kuppo — Új kapcsolatfelvétel" />
          <input type="hidden" name="from_name" value="Kuppo Landing" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" aria-hidden="true" />
          <div class="flex flex-col gap-5">

            <div class="flex flex-col gap-1.5">
              <label
                for="contact-name"
                class="text-sm font-medium"
                style="color: var(--color-text);"
              >
                Név <span aria-hidden="true" style="color: var(--color-primary);">*</span>
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Kovács Anna"
                class="rounded-lg py-3 px-4 text-base border outline-none transition-shadow duration-150"
                style="border-color: var(--color-border); color: var(--color-text); background-color: var(--color-bg);"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="contact-email"
                class="text-sm font-medium"
                style="color: var(--color-text);"
              >
                Email <span aria-hidden="true" style="color: var(--color-primary);">*</span>
              </label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="kovacs.anna@example.com"
                class="rounded-lg py-3 px-4 text-base border outline-none transition-shadow duration-150"
                style="border-color: var(--color-border); color: var(--color-text); background-color: var(--color-bg);"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="contact-business"
                class="text-sm font-medium"
                style="color: var(--color-text);"
              >
                Üzlet neve
              </label>
              <input
                id="contact-business"
                name="business"
                type="text"
                autocomplete="organization"
                placeholder="Bella Kávézó"
                class="rounded-lg py-3 px-4 text-base border outline-none transition-shadow duration-150"
                style="border-color: var(--color-border); color: var(--color-text); background-color: var(--color-bg);"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="contact-message"
                class="text-sm font-medium"
                style="color: var(--color-text);"
              >
                Üzenet <span aria-hidden="true" style="color: var(--color-primary);">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="4"
                placeholder="Miben segíthetünk?"
                class="rounded-lg py-3 px-4 text-base border outline-none transition-shadow duration-150 resize-none"
                style="border-color: var(--color-border); color: var(--color-text); background-color: var(--color-bg);"
              ></textarea>
            </div>

            <button
              type="submit"
              class="contact-submit inline-flex items-center justify-center gap-2 w-full py-3.5 px-6 rounded-xl text-base font-semibold text-white transition-all duration-200 hover:brightness-110 active:scale-[0.98] mt-1"
              style="background-color: var(--color-accent);"
            >
              Küldés
              <Send size={18} aria-hidden="true" />
            </button>

          </div>
        </form>

        <!-- Success message (hidden by default) -->
        <div
          id="contact-success"
          class="hidden text-center py-8"
          role="alert"
          aria-live="polite"
        >
          <div
            class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-5"
            style="background-color: color-mix(in srgb, var(--color-success) 12%, transparent);"
          >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
              <path d="M5.5 14 11 19.5 22.5 8" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-lg font-semibold mb-2" style="font-family: var(--font-heading); color: var(--color-text);">
            Köszönjük!
          </p>
          <p class="text-base" style="color: var(--color-text-secondary);">
            Hamarosan felvesszük veled a kapcsolatot.
          </p>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .contact-section {
    background: color-mix(in srgb, var(--color-accent-light) 25%, var(--color-surface));
  }

  #contact-form input:focus,
  #contact-form textarea:focus {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-primary);
    border-color: var(--color-primary);
  }

  .contact-card:focus-within {
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border)) !important;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 1px color-mix(in srgb, var(--color-primary) 15%, transparent) !important;
  }

  .contact-submit:hover {
    box-shadow: 0 8px 25px color-mix(in srgb, var(--color-accent) 35%, transparent), 0 4px 10px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const successMsg = document.getElementById("contact-success");
  const submitBtn = form?.querySelector("button[type=submit]") as HTMLButtonElement | null;

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitBtn.textContent = loading ? "Küldés…" : "Küldés";
  }

  function showFieldError(fieldId: string, msg: string) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.style.borderColor = "#dc2626";
    field.style.boxShadow = "0 0 0 2px #dc2626";
    let errEl = document.getElementById(`${fieldId}-error`);
    if (!errEl) {
      errEl = document.createElement("p");
      errEl.id = `${fieldId}-error`;
      errEl.className = "mt-1 text-xs font-medium";
      errEl.style.color = "#dc2626";
      errEl.setAttribute("role", "alert");
      field.parentNode?.appendChild(errEl);
    }
    errEl.textContent = msg;
  }

  function clearFieldErrors() {
    ["contact-name", "contact-email", "contact-message"].forEach((id) => {
      const field = document.getElementById(id);
      if (field) {
        field.style.borderColor = "";
        field.style.boxShadow = "";
      }
      document.getElementById(`${id}-error`)?.remove();
    });
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearFieldErrors();

    const nameVal = (document.getElementById("contact-name") as HTMLInputElement)?.value.trim();
    const emailVal = (document.getElementById("contact-email") as HTMLInputElement)?.value.trim();
    const messageVal = (document.getElementById("contact-message") as HTMLTextAreaElement)?.value.trim();

    let hasError = false;
    if (!nameVal) { showFieldError("contact-name", "A neved megadása kötelező."); hasError = true; }
    if (!emailVal) { showFieldError("contact-email", "Az e-mail cím megadása kötelező."); hasError = true; }
    if (!messageVal) { showFieldError("contact-message", "Az üzenet megadása kötelező."); hasError = true; }
    if (hasError) return;

    setLoading(true);

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
      });

      const data = await res.json();

      if (!data.success) {
        throw new Error(data.message || "Web3Forms error");
      }

      form.classList.add("hidden");
      successMsg?.classList.remove("hidden");
    } catch (err) {
      console.error("Contact form error:", err);
      showFieldError("contact-message", "Valami hiba történt. Kérlek, próbáld újra.");
    } finally {
      setLoading(false);
    }
  });
</script>

---
---

<section
  class="relative min-h-screen flex items-center bg-[var(--color-bg)] pt-32 pb-32 overflow-hidden"
  aria-label="Hero"
>
  <!-- Background gradient blobs -->
  <div
    class="pointer-events-none absolute -top-40 -right-40 w-[900px] h-[900px] rounded-full"
    style="background: radial-gradient(circle, var(--color-primary) 0%, transparent 65%); opacity: 0.12;"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-20 -left-20 w-[640px] h-[640px] rounded-full"
    style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 65%); opacity: 0.08;"
  ></div>

  <div class="max-w-7xl mx-auto px-6 w-full relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text column -->
      <div class="flex flex-col gap-8">

        <!-- Eyebrow badge -->
        <div class="inline-flex self-start items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium"
          style="background: var(--color-primary-light); color: var(--color-primary);">
          <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
          Hamarosan elérhető
        </div>

        <!-- Headline -->
        <h1
          class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.08] tracking-tight"
          style="color: var(--color-text);"
        >
          Törzsvásárlóid<br />
          <span style="color: var(--color-primary);">egy koppintásra</span>
        </h1>

        <!-- Subline -->
        <p class="text-lg lg:text-xl leading-relaxed max-w-md" style="color: var(--color-text-secondary);">
          Digitális pecsétgyűjtő kártya kisvállalkozásoknak. Nincs papír, nincs plasztik —
          csak elégedett visszatérő vendégek.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <a
            href="#varolista"
            class="inline-flex items-center justify-center gap-2 px-10 py-5 rounded-2xl font-semibold text-white text-lg transition-all duration-300 ease-out hover:brightness-110 hover:scale-[1.02] active:scale-[0.98]"
            style="background: var(--color-accent); box-shadow: 0 6px 28px color-mix(in srgb, var(--color-accent) 38%, transparent);"
          >
            Feliratkozom
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <a
            href="#hogyan-mukodik"
            class="inline-flex items-center gap-2 px-2 py-4 font-medium text-base transition-colors duration-150 group"
            style="color: var(--color-primary);"
          >
            Megnézem hogyan működik
            <svg
              width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"
              class="transition-transform duration-200 group-hover:translate-x-1"
            >
              <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Trust line -->
        <p class="text-sm flex items-center gap-2.5" style="color: var(--color-text-secondary);">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink: 0; color: var(--color-success);">
            <path d="M8 1.333A6.667 6.667 0 1 0 8 14.667 6.667 6.667 0 0 0 8 1.333Zm3.138 5.138-3.667 3.667a.667.667 0 0 1-.943 0L4.862 8.47a.667.667 0 1 1 .943-.943L7.1 8.724l3.195-3.195a.667.667 0 0 1 .943.943Z" fill="currentColor"/>
          </svg>
          Ingyenes indulás · Nem kell bankkártya
        </p>
      </div>

      <!-- Phone mockup column -->
      <div class="flex justify-center lg:justify-end items-center">
        <div class="relative phone-float">
          <!-- Glow beneath the phone -->
          <div
            class="absolute inset-x-8 -bottom-8 h-24 blur-2xl rounded-full"
            style="background: var(--color-primary); opacity: 0.35;"
          ></div>

          <!-- Phone outer shell -->
          <div
            class="relative rounded-[3rem] shadow-2xl overflow-hidden"
            style="
              width: 280px;
              height: 580px;
              background: #1a1a2e;
              box-shadow:
                0 0 0 2px #2d2d4a,
                0 32px 64px rgba(0,0,0,0.35),
                inset 0 1px 0 rgba(255,255,255,0.08);
            "
          >
            <!-- Side buttons (decorative) -->
            <div class="absolute -right-1 top-28 w-1 h-8 rounded-l-sm" style="background: #2d2d4a;"></div>
            <div class="absolute -left-1 top-24 w-1 h-6 rounded-r-sm" style="background: #2d2d4a;"></div>
            <div class="absolute -left-1 top-32 w-1 h-6 rounded-r-sm" style="background: #2d2d4a;"></div>

            <!-- Screen bezel -->
            <div class="absolute inset-[3px] rounded-[2.7rem] overflow-hidden" style="background: #ffffff;">

              <!-- Status bar -->
              <div class="flex items-center justify-between px-6 pt-4 pb-2" style="color: var(--color-text);">
                <span class="text-xs font-medium" style="font-family: var(--font-body);">9:41</span>
                <div class="flex items-center gap-1.5">
                  <!-- Signal bars -->
                  <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                    <rect x="0" y="6" width="2.5" height="4" rx="0.5" fill="#1C1917" opacity="0.4"/>
                    <rect x="3.5" y="4" width="2.5" height="6" rx="0.5" fill="#1C1917" opacity="0.55"/>
                    <rect x="7" y="2" width="2.5" height="8" rx="0.5" fill="#1C1917" opacity="0.7"/>
                    <rect x="10.5" y="0" width="2.5" height="10" rx="0.5" fill="#1C1917" opacity="0.85"/>
                  </svg>
                  <!-- Battery -->
                  <svg width="22" height="12" viewBox="0 0 22 12" fill="none" aria-hidden="true">
                    <rect x="0.5" y="0.5" width="18" height="11" rx="2.5" stroke="#1C1917" stroke-opacity="0.4"/>
                    <rect x="2" y="2" width="13" height="8" rx="1.5" fill="#1C1917" opacity="0.7"/>
                    <path d="M20 4v4a2 2 0 0 0 0-4Z" fill="#1C1917" opacity="0.4"/>
                  </svg>
                </div>
              </div>

              <!-- Notch / Dynamic island -->
              <div
                class="absolute top-3 left-1/2 -translate-x-1/2 rounded-full"
                style="width: 96px; height: 30px; background: #1C1917; z-index: 10;"
              ></div>

              <!-- App screen content -->
              <div class="px-5 pb-6 flex flex-col gap-4" style="padding-top: 2.5rem;">

                <!-- App header -->
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-xs" style="color: var(--color-text-secondary); font-family: var(--font-body);">Üdv újra,</p>
                    <p class="text-sm font-semibold" style="color: var(--color-text); font-family: var(--font-heading);">Kávézó Krisztián</p>
                  </div>
                  <div
                    class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold"
                    style="background: var(--color-primary); color: white; font-family: var(--font-heading);"
                  >KK</div>
                </div>

                <!-- Stamp card -->
                <div
                  class="rounded-2xl p-4 flex flex-col gap-3"
                  style="background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); box-shadow: 0 8px 24px rgba(79,70,229,0.3);"
                >
                  <!-- Card header -->
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="text-xs font-medium" style="color: rgba(255,255,255,0.55); font-family: var(--font-body);">Hűségkártya</p>
                      <p class="text-sm font-bold text-white leading-tight" style="font-family: var(--font-heading);">10 kávé = 1 ingyenes</p>
                    </div>
                    <!-- Coffee cup icon -->
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: rgba(255,255,255,0.1);">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M4 7h9v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z" stroke="white" stroke-width="1.4" stroke-linejoin="round"/>
                        <path d="M13 9h1.5a1.5 1.5 0 0 1 0 3H13" stroke="white" stroke-width="1.4" stroke-linecap="round"/>
                        <path d="M7 4.5c0-1 1-1.5 1-2.5" stroke="white" stroke-width="1.3" stroke-linecap="round"/>
                        <path d="M10 4.5c0-1 1-1.5 1-2.5" stroke="white" stroke-width="1.3" stroke-linecap="round"/>
                      </svg>
                    </div>
                  </div>

                  <!-- Stamp grid -->
                  <div class="grid grid-cols-5 gap-2">
                    <!-- Stamped (amber) -->
                    <div class="w-full aspect-square rounded-lg flex items-center justify-center" style="background: var(--color-accent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 50%, transparent);">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M2.5 7 5.5 10 11.5 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="w-full aspect-square rounded-lg flex items-center justify-center" style="background: var(--color-accent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 50%, transparent);">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M2.5 7 5.5 10 11.5 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="w-full aspect-square rounded-lg flex items-center justify-center" style="background: var(--color-accent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 50%, transparent);">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M2.5 7 5.5 10 11.5 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="w-full aspect-square rounded-lg flex items-center justify-center" style="background: var(--color-accent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 50%, transparent);">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M2.5 7 5.5 10 11.5 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="w-full aspect-square rounded-lg flex items-center justify-center" style="background: var(--color-accent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 50%, transparent);">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M2.5 7 5.5 10 11.5 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <!-- Empty stamps (clickable) -->
                    <div class="stamp-empty w-full aspect-square rounded-lg cursor-pointer transition-transform duration-150 hover:scale-110" style="background: rgba(255,255,255,0.1); border: 1.5px dashed rgba(255,255,255,0.2);"></div>
                    <div class="stamp-empty w-full aspect-square rounded-lg cursor-pointer transition-transform duration-150 hover:scale-110" style="background: rgba(255,255,255,0.1); border: 1.5px dashed rgba(255,255,255,0.2);"></div>
                    <div class="stamp-empty w-full aspect-square rounded-lg cursor-pointer transition-transform duration-150 hover:scale-110" style="background: rgba(255,255,255,0.1); border: 1.5px dashed rgba(255,255,255,0.2);"></div>
                    <div class="stamp-empty w-full aspect-square rounded-lg cursor-pointer transition-transform duration-150 hover:scale-110" style="background: rgba(255,255,255,0.1); border: 1.5px dashed rgba(255,255,255,0.2);"></div>
                    <!-- 10th: trophy / reward slot -->
                    <div class="stamp-empty w-full aspect-square rounded-lg flex items-center justify-center cursor-pointer transition-transform duration-150 hover:scale-110" style="background: rgba(255,255,255,0.07); border: 1.5px dashed rgba(255,255,255,0.3);">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M7 1.5 8.545 5.06l3.88.563-2.808 2.735.663 3.863L7 10.5l-3.28 1.72.663-3.862L1.575 5.624l3.88-.563L7 1.5Z" stroke="rgba(255,255,255,0.4)" stroke-width="1.3" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </div>

                  <!-- Progress label -->
                  <div class="flex items-center justify-between">
                    <p id="stamp-count" class="text-xs" style="color: rgba(255,255,255,0.5); font-family: var(--font-body);">5 / 10 pecsét</p>
                    <p id="stamp-hint" class="text-xs font-semibold" style="color: var(--color-accent); font-family: var(--font-body);">Még 5 a jutalmadhoz!</p>
                  </div>

                  <!-- Star celebration (hidden until all collected) -->
                  <div id="stamp-done" class="hidden flex items-center justify-center gap-2 py-1">
                    <svg class="stamp-star" width="20" height="20" viewBox="0 0 48 48" fill="none">
                      <path d="M24 4l6.18 12.52L44 18.52l-10 9.74 2.36 13.74L24 35.76 11.64 42l2.36-13.74-10-9.74 13.82-2L24 4Z" fill="#F59E0B"/>
                    </svg>
                    <p class="text-xs font-bold text-white" style="font-family: var(--font-heading);">Ajándék kávé!</p>
                    <svg class="stamp-star" width="20" height="20" viewBox="0 0 48 48" fill="none">
                      <path d="M24 4l6.18 12.52L44 18.52l-10 9.74 2.36 13.74L24 35.76 11.64 42l2.36-13.74-10-9.74 13.82-2L24 4Z" fill="#F59E0B"/>
                    </svg>
                  </div>
                </div>

                <!-- Recent activity -->
                <div class="flex flex-col gap-2">
                  <p class="text-xs font-medium" style="color: var(--color-text-secondary); font-family: var(--font-body);">Legutóbbi látogatások</p>
                  <div class="flex items-center justify-between py-1.5">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-full flex items-center justify-center" style="background: rgba(245,158,11,0.15);">
                        <div class="w-2.5 h-2.5 rounded-full" style="background: var(--color-accent);"></div>
                      </div>
                      <p class="text-xs" style="color: var(--color-text); font-family: var(--font-body);">Pecsét megszerezve</p>
                    </div>
                    <p class="text-xs" style="color: var(--color-text-secondary); font-family: var(--font-body);">ma</p>
                  </div>
                  <div class="flex items-center justify-between py-1.5">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-full flex items-center justify-center" style="background: rgba(245,158,11,0.15);">
                        <div class="w-2.5 h-2.5 rounded-full" style="background: var(--color-accent);"></div>
                      </div>
                      <p class="text-xs" style="color: var(--color-text); font-family: var(--font-body);">Pecsét megszerezve</p>
                    </div>
                    <p class="text-xs" style="color: var(--color-text-secondary); font-family: var(--font-body);">tegnap</p>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Phone float animation */
  @keyframes phone-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }

  .phone-float {
    animation: phone-float 3.5s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-float {
      animation: none;
    }
  }



  @keyframes stamp-pop {
    0% { transform: scale(0.3); opacity: 0; }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes star-spin {
    0% { transform: scale(0) rotate(-60deg); opacity: 0; }
    60% { transform: scale(1.3) rotate(10deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  #stamp-done.show {
    animation: stamp-pop 0.4s ease-out;
  }

  #stamp-done.show .stamp-star {
    animation: star-spin 0.5s ease-out both;
  }

  #stamp-done.show .stamp-star:last-child {
    animation-delay: 0.1s;
  }
</style>

<script>
  const TOTAL = 10;
  const checkSvg = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7 5.5 10 11.5 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

  const slots = document.querySelectorAll(".stamp-empty");
  const countEl = document.getElementById("stamp-count");
  const hintEl = document.getElementById("stamp-hint");
  const doneEl = document.getElementById("stamp-done");
  let filled = 5;

  slots.forEach((slot) => {
    slot.addEventListener("click", () => {
      filled++;
      slot.innerHTML = checkSvg;
      slot.className = "w-full aspect-square rounded-lg flex items-center justify-center";
      slot.removeAttribute("style");
      slot.style.background = "var(--color-accent)";
      slot.style.boxShadow = "0 2px 8px color-mix(in srgb, var(--color-accent) 50%, transparent)";
      slot.style.animation = "stamp-pop 0.35s ease-out";

      if (countEl) countEl.textContent = `${filled} / ${TOTAL} pecsét`;

      if (filled >= TOTAL) {
        if (hintEl) hintEl.textContent = "";
        if (doneEl) {
          doneEl.classList.remove("hidden");
          doneEl.classList.add("show");
        }
      } else {
        const remaining = TOTAL - filled;
        if (hintEl) hintEl.textContent = `Még ${remaining} a jutalmadhoz!`;
      }
    }, { once: true });
  });
</script>

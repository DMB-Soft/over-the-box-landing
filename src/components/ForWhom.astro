---
import Coffee from '@lucide/astro/icons/coffee';
import Croissant from '@lucide/astro/icons/croissant';
import Scissors from '@lucide/astro/icons/scissors';
import UtensilsCrossed from '@lucide/astro/icons/utensils-crossed';

const merchants = [
  {
    Icon: Coffee,
    title: 'Kávézó',
    description: 'Törzskávézók, akik minden reggel visszajönnek',
  },
  {
    Icon: Croissant,
    title: 'Pékség',
    description: 'A friss péksütemény mellé hűséget is kínálj',
  },
  {
    Icon: Scissors,
    title: 'Szalon',
    description: 'Jutalmazd a rendszeres vendégeidet',
  },
  {
    Icon: UtensilsCrossed,
    title: 'Étterem',
    description: 'Ebédmenü + hűségprogram = telt ház',
  },
];
---

<section id="kiknek" class="animate-on-scroll py-28" style="background-color: var(--color-surface);">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2
        class="text-3xl md:text-4xl font-bold mb-4"
        style="font-family: var(--font-heading); color: var(--color-text);"
      >
        Kinek való?
      </h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">
        Ha visszatérő vendégekből élsz, neked találtuk ki.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
      {merchants.map(({ Icon, title, description }) => (
        <div
          class="merchant-card flex flex-col items-center text-center gap-5 rounded-2xl px-6 py-8 transition-all duration-300 ease-out hover:shadow-md hover:-translate-y-0.5 cursor-default"
          style="border: 1px solid var(--color-border); background-color: var(--color-surface);"
        >
          <div
            class="w-20 h-20 rounded-2xl flex items-center justify-center"
            style="background-color: var(--color-accent-light);"
          >
            <Icon size={36} style="color: var(--color-accent);" />
          </div>
          <div>
            <h3
              class="text-lg font-semibold mb-2"
              style="font-family: var(--font-heading); color: var(--color-text);"
            >
              {title}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .merchant-card {
      transition: none;
    }
  }
</style>
